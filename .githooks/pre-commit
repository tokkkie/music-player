#!/bin/bash

# ============================================
# main直接コミット禁止チェック
# ============================================
protected_branch="main"
current_branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$current_branch" = "$protected_branch" ]; then
    echo "--------------------------------------------------"
    echo "ERROR: mainへの直接コミットは禁止されています。"
    echo "作業用ブランチを作成し、そこにコミットしてください。"
    echo "ブランチをpushし、GitHub上でPRを作成してください。"
    echo "--------------------------------------------------"
    exit 1
fi

# ============================================
# .gitignore対象ファイルの強制addチェック
# ============================================
# git ls-files --others --ignored --exclude-standard で無視されているファイルを取得
ignored_files=$(git ls-files --others --ignored --exclude-standard)
staged_ignored=$(git diff --cached --name-only | grep -Fxf <(echo "$ignored_files"))

if [ -n "$staged_ignored" ]; then
    echo "--------------------------------------------------"
    echo "ERROR: .gitignore対象ファイルがコミットされようとしています。"
    echo "以下のファイルは .gitignore で除外されていますが、stagedに含まれています:"
    echo "$staged_ignored"
    echo ".gitignoreの設定を尊重し、これらのファイルをコミットから除外してください。"
    echo "--------------------------------------------------"
    exit 1
fi

# ============================================
# ファイル形式チェック（エンコーディング・改行コード・末尾改行）
# ============================================
# stagedされたファイルを取得
staged_files=$(git diff --cached --name-only --diff-filter=ACM)

for file in $staged_files; do
    # バイナリファイルはスキップ
    if git diff --cached --numstat "$file" | grep -q '^-' ; then
        continue
    fi

    # ファイルが存在するか確認
    if [ ! -f "$file" ]; then
        continue
    fi

    # バイナリチェック（fileコマンド）
    file_type=$(file "$file" --mime-type)
    if echo "$file_type" | grep -q 'text/'; then
        # テキストファイルのみチェック

        # BOMチェック
        if [ "$(head -c 3 "$file" | od -A n -t x1 | tr -d ' ')" = "efbbbf" ]; then
            echo "--------------------------------------------------"
            echo "ERROR: $file にUTF-8 BOMが含まれています。"
            echo "BOMなしのUTF-8（BOMなし）を使用してください。"
            echo "--------------------------------------------------"
            exit 1
        fi

        # 改行コードチェック（CRLF禁止）
        if file "$file" | grep -q 'CRLF'; then
            echo "--------------------------------------------------"
            echo "ERROR: $file にCRLF改行が含まれています。"
            echo "LF改行のみを使用してください。"
            echo "--------------------------------------------------"
            exit 1
        fi

        # 末尾改行チェック
        if [ "$(tail -c 1 "$file" | wc -l)" -eq 0 ]; then
            echo "--------------------------------------------------"
            echo "ERROR: $file の末尾に改行がありません。"
            echo "すべてのコードファイル末尾に改行（LF）を入れてください。"
            echo "--------------------------------------------------"
            exit 1
        fi
    fi
done

# ============================================
# 秘匿情報チェック
# ============================================
# stagedされたファイルの内容をチェック
for file in $staged_files; do
    if [ ! -f "$file" ]; then
        continue
    fi

    # バイナリファイルはスキップ
    file_type=$(file "$file" --mime-type)
    if ! echo "$file_type" | grep -q 'text/'; then
        continue
    fi

    # 秘匿情報パターン
    patterns=(
        "api[_-]?key\s*=\s*['\"][^'\"]+['\"]"
        "api[_-]?secret\s*=\s*['\"][^'\"]+['\"]"
        "password\s*=\s*['\"][^'\"]+['\"]"
        "token\s*=\s*['\"][^'\"]+['\"]"
        "secret[_-]?key\s*=\s*['\"][^'\"]+['\"]"
        "access[_-]?token\s*=\s*['\"][^'\"]+['\"]"
        "refresh[_-]?token\s*=\s*['\"][^'\"]+['\"]"
        "private[_-]?key\s*=\s*['\"][^'\"]+['\"]"
        "aws[_-]?access[_-]?key[_-]?id\s*=\s*['\"][^'\"]+['\"]"
        "aws[_-]?secret[_-]?access[_-]?key\s*=\s*['\"][^'\"]+['\"]"
    )

    for pattern in "${patterns[@]}"; do
        if grep -iE "$pattern" "$file" > /dev/null 2>&1; then
            echo "--------------------------------------------------"
            echo "ERROR: $file に秘匿情報が含まれている可能性があります。"
            echo "パターン: $pattern"
            echo "秘匿情報は環境変数またはSecret Managerを使用してください。"
            echo "コード・ログ・コミットに含めないでください。"
            echo "--------------------------------------------------"
            exit 1
        fi
    done
done

# ============================================
# CI/CDシークレット直書きチェック
# ============================================
# CI設定ファイル（.github/workflows/*.yml, .gitlab-ci.yml等）に
# シークレット値が「リテラル」として直書きされていないかを検査する。
#
# 方針:
#   - `${{ secrets.* }}` / `${{ env.* }}` / `${{ vars.* }}` / `${{ inputs.* }}` 等の
#     expression 参照は GitHub Actions 公式の正しい注入方法であり、検出対象外とする。
#   - 検出対象は `password: "..."` や `token: "ghp_xxx"` のような **引用符付きリテラル値**。
#   - 既知シークレット形式（AWS/GCP/Slack token 等）と高エントロピー値は
#     gitleaks（本ファイル末尾で実行）および CI 側の gitleaks job が担当する。
#
# パターン: `(password|token|secret|api[_-]?key):` の直後に引用符付きリテラルが続く形。
#           expression 参照 `${{ ... }}` を含む行は除外。
ci_literal_pattern="^[[:space:]]*[A-Za-z0-9_-]*(password|token|secret|api[_-]?key)[A-Za-z0-9_-]*:[[:space:]]*[\"'][^\"']+[\"'][[:space:]]*\$"

for file in $staged_files; do
    if [ ! -f "$file" ]; then
        continue
    fi

    # CI設定ファイルのみチェック
    if echo "$file" | grep -qE '\.(github|gitlab)'; then
        # expression 参照行 (`${{ ... }}` を含む行) を除外した上で、
        # 引用符付きリテラル値を検出
        hits=$(grep -inE "$ci_literal_pattern" "$file" | grep -vE '\$\{\{')
        if [ -n "$hits" ]; then
            echo "--------------------------------------------------"
            echo "ERROR: $file にシークレットがリテラル値で直書きされている可能性があります。"
            echo "CI/CDシークレットは \${{ secrets.* }} / \${{ vars.* }} 等の expression 参照を使用してください。"
            echo "$hits" >&2
            echo "--------------------------------------------------"
            exit 1
        fi
    fi
done

# ============================================
# 機密情報・環境固有情報スキャン（汎用）
# ============================================
# ローカルパス、プライベートネットワーク、プライベートリポジトリ識別子等、
# 環境固有情報が staged ファイルに混入していないかを検査する。
# パターン定義: .githooks/sensitive-patterns.txt
. "$(dirname "$0")/lib/scan-sensitive.sh"

for file in $staged_files; do
    [ ! -f "$file" ] && continue

    file_type=$(file "$file" --mime-type)
    echo "$file_type" | grep -q 'text/' || continue

    # パターン定義ファイル自身は対象外（自己参照による誤検知回避）
    case "$file" in
        .githooks/sensitive-patterns.txt) continue ;;
    esac

    if ! scan_sensitive_file "$file"; then
        echo "--------------------------------------------------" >&2
        echo "ERROR: $file に機密情報の可能性があるパターンを検出しました。" >&2
        echo "パターン定義: .githooks/sensitive-patterns.txt" >&2
        echo "--------------------------------------------------" >&2
        exit 1
    fi
done

# ============================================
# gitleaks による既知シークレット検出（optional）
# ============================================
# ローカルにインストールされていれば予防層として動作。
# 未インストールでも CI (.github/workflows/sensitive-info-guard.yml) が最終ゲートとなる。
if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --redact --no-banner; then
        echo "--------------------------------------------------" >&2
        echo "ERROR: gitleaks が既知のシークレットパターンを検出しました。" >&2
        echo "該当箇所を削除してから再コミットしてください。" >&2
        echo "--------------------------------------------------" >&2
        exit 1
    fi
else
    echo "INFO: gitleaks 未インストール（スキップ）。CI で最終チェックされます。"
    echo "      推奨インストール: https://github.com/gitleaks/gitleaks#installing"
fi
